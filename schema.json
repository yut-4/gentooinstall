{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "gentooinstall Config",
  "description": "Schema for gentooinstall JSON configuration files",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string"
    },
    "script": {
      "type": "string",
      "enum": [
        "guided",
        "minimal",
        "only_hd"
      ]
    },
    "gentooinstall-language": {
      "description": "Installer language label",
      "type": "string"
    },
    "hostname": {
      "type": "string"
    },
    "timezone": {
      "type": "string"
    },
    "ntp": {
      "type": "boolean"
    },
    "offline": {
      "type": "boolean"
    },
    "no_pkg_lookups": {
      "type": "boolean"
    },
    "kernels": {
      "description": "List of kernels to install",
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "gentoo-kernel-bin",
          "gentoo-kernel",
          "hardened-sources",
          "linux",
          "linux-lts",
          "linux-zen",
          "linux-hardened"
        ]
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "parallel_downloads": {
      "type": "integer",
      "minimum": 0
    },
    "parallel downloads": {
      "description": "Deprecated key. Use parallel_downloads",
      "type": "integer",
      "minimum": 0
    },
    "services": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "custom_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disk_config": {
      "type": "object"
    },
    "locale_config": {
      "type": "object",
      "properties": {
        "kb_layout": {
          "type": "string"
        },
        "sys_enc": {
          "type": "string"
        },
        "sys_lang": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "mirror_config": {
      "type": "object"
    },
    "network_config": {
      "type": "object"
    },
    "profile_config": {
      "type": "object"
    },
    "app_config": {
      "type": "object"
    },
    "auth_config": {
      "type": "object"
    },
    "swap": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object"
        }
      ]
    },
    "bootloader_config": {
      "description": "Primary bootloader settings",
      "type": "object",
      "properties": {
        "bootloader": {
          "type": "string",
          "enum": [
            "No bootloader",
            "Systemd-boot",
            "Grub",
            "Efistub",
            "Limine",
            "Refind"
          ]
        },
        "uki": {
          "type": "boolean"
        },
        "removable": {
          "type": "boolean"
        }
      },
      "required": [
        "bootloader"
      ],
      "additionalProperties": false
    },
    "bootloader": {
      "description": "Deprecated key. Use bootloader_config.bootloader",
      "type": "string",
      "enum": [
        "Systemd-boot",
        "Grub",
        "Efistub",
        "Limine",
        "Refind",
        "No bootloader"
      ]
    },
    "uki": {
      "description": "Deprecated key. Use bootloader_config.uki",
      "type": "boolean"
    },
    "gentoo": {
      "description": "Gentoo-specific options for architecture, stage3, Portage sync and make.conf",
      "type": "object",
      "properties": {
        "architecture": {
          "description": "Target architecture. Use auto to detect from host machine",
          "type": "string",
          "enum": [
            "auto",
            "amd64",
            "arm64",
            "arm",
            "x86",
            "ppc",
            "ppc64",
            "hppa",
            "mips",
            "riscv",
            "s390",
            "sparc",
            "alpha",
            "loong"
          ]
        },
        "init_system": {
          "description": "Init system for stage3 selection and service handling",
          "type": "string",
          "enum": [
            "systemd",
            "openrc"
          ]
        },
        "stage3_url": {
          "description": "Optional explicit stage3 tarball URL override",
          "type": "string"
        },
        "stage3_flavor": {
          "description": "Optional stage3 token override for uncommon variants",
          "type": "string"
        },
        "profile": {
          "description": "Optional eselect profile path",
          "type": "string"
        },
        "sync_mode": {
          "description": "How to synchronize /var/db/repos/gentoo",
          "type": "string",
          "enum": [
            "sync",
            "webrsync",
            "none"
          ]
        },
        "use_wgetload": {
          "description": "Use wgetload helper for stage3 download resolution",
          "type": "boolean"
        },
        "make_conf": {
          "description": "Values merged into /etc/portage/make.conf",
          "type": "object",
          "properties": {
            "common_flags": {
              "type": "string"
            },
            "cflags": {
              "type": "string"
            },
            "cxxflags": {
              "type": "string"
            },
            "fcflags": {
              "type": "string"
            },
            "fflags": {
              "type": "string"
            },
            "rustflags": {
              "type": "string"
            },
            "chost": {
              "type": "string"
            },
            "makeopts": {
              "type": "string"
            },
            "emerge_default_opts": {
              "type": "string"
            },
            "use": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "features": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "accept_license": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "video_cards": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "grub_platforms": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "extra": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
