{
  "gentooinstall-language": "English",
  "script": "guided",
  "hostname": "gentoo-uefi",
  "timezone": "UTC",
  "ntp": true,
  "offline": false,
  "kernels": [
    "gentoo-kernel-bin"
  ],
  "bootloader_config": {
    "bootloader": "Grub",
    "uki": false,
    "removable": false
  },
  "disk_config": {
    "config_type": "default_layout",
    "device_modifications": [
      {
        "device": "/dev/sda",
        "partitions": [
          {
            "btrfs": [],
            "flags": [
              "boot"
            ],
            "fs_type": "fat32",
            "size": {
              "sector_size": null,
              "unit": "MiB",
              "value": 512
            },
            "mount_options": [],
            "mountpoint": "/boot",
            "obj_id": "11111111-1111-4111-8111-111111111111",
            "start": {
              "sector_size": null,
              "unit": "MiB",
              "value": 1
            },
            "status": "create",
            "type": "primary"
          },
          {
            "btrfs": [],
            "flags": [],
            "fs_type": "ext4",
            "size": {
              "sector_size": null,
              "unit": "GiB",
              "value": 40
            },
            "mount_options": [],
            "mountpoint": "/",
            "obj_id": "22222222-2222-4222-8222-222222222222",
            "start": {
              "sector_size": null,
              "unit": "MiB",
              "value": 513
            },
            "status": "create",
            "type": "primary"
          },
          {
            "btrfs": [],
            "flags": [],
            "fs_type": "ext4",
            "size": {
              "sector_size": null,
              "unit": "Percent",
              "value": 100
            },
            "mount_options": [],
            "mountpoint": "/home",
            "obj_id": "33333333-3333-4333-8333-333333333333",
            "start": {
              "sector_size": null,
              "unit": "GiB",
              "value": 40
            },
            "status": "create",
            "type": "primary"
          }
        ],
        "wipe": true
      }
    ]
  },
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US"
  },
  "mirror_config": {
    "custom_servers": [
      {
        "url": "https://distfiles.gentoo.org/"
      }
    ],
    "mirror_regions": {
      "Worldwide": [
        "https://distfiles.gentoo.org/"
      ]
    },
    "optional_repositories": [],
    "custom_repositories": []
  },
  "network_config": {
    "type": "manual",
    "nics": [
      {
        "iface": "eno1",
        "dhcp": true
      }
    ]
  },
  "gentoo": {
    "architecture": "amd64",
    "init_system": "systemd",
    "sync_mode": "sync",
    "use_wgetload": true,
    "profile": "default/linux/amd64/23.0/systemd",
    "make_conf": {
      "common_flags": "-O2 -pipe",
      "cflags": "${COMMON_FLAGS}",
      "cxxflags": "${COMMON_FLAGS}",
      "makeopts": "-j8",
      "emerge_default_opts": "--jobs 8 --load-average 8",
      "features": [
        "parallel-fetch"
      ],
      "grub_platforms": [
        "efi-64"
      ]
    }
  },
  "packages": [
    "sys-boot/os-prober"
  ],
  "parallel_downloads": 5,
  "services": [],
  "custom_commands": [],
  "version": "3.0.2"
}
