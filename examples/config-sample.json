            "fs_type": "ext4",
            "size": {
              "sector_size": null,
              "unit": "GiB",
              "value": 20
            },
            "mount_options": [],
            "mountpoint": "/",
            "obj_id": "3e7018a0-363b-4d05-ab83-8e82d13db208",
            "start": {
              "sector_size": null,
              "unit": "MiB",
