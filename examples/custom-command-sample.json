{
  "script": "guided",
  "hostname": "development-box",
  "kernels": [
    "gentoo-kernel-bin"
  ],
  "bootloader_config": {
    "bootloader": "Grub",
    "uki": false,
    "removable": false
  },
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US"
  },
  "ntp": true,
  "packages": [
    "app-containers/docker",
    "dev-vcs/git",
    "net-misc/wget",
    "app-shells/zsh"
  ],
  "services": [
    "docker"
  ],
  "timezone": "UTC",
  "custom_commands": [
    "emerge --sync",
    "usermod -aG docker devel"
  ]
}
